# ── Legiferam.ro — PRODUCTION environment template ────────────────────────
# Copy to `.env` ON THE SERVER and fill in real values. NEVER commit the real .env.
# Generate secrets:  openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=legiferam
POSTGRES_PASSWORD=__SET_A_STRONG_PASSWORD__
POSTGRES_DB=legiferam
DATABASE_URL=postgresql+psycopg://legiferam:__SET_A_STRONG_PASSWORD__@db:5432/legiferam

# ── Auth ──────────────────────────────────────────────────────────────────
# Keep demo/demo only if you want a public demo login; otherwise change them.
DEMO_USER=demo
DEMO_PASS=demo
JWT_SECRET=__RUN_openssl_rand_-hex_32__
JWT_EXPIRE_MINUTES=720

# ── AI (OpenRouter) — backend only ────────────────────────────────────────
OPENROUTER_API_KEY=__YOUR_OPENROUTER_KEY__
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://legiferam.ro
OPENROUTER_APP_NAME=Legiferam.ro
# In production the co-pilot runs live. Set true to force scripted replies.
AI_DEMO_SCRIPTED=false

# ── Web ───────────────────────────────────────────────────────────────────
# Host port the web (nginx) container binds; NPM forwards the domain → this port.
WEB_PORT=8080
VITE_API_BASE=/api
