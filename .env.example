# ── Legiferam.ro environment ──────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=legiferam
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=legiferam
# Inside docker-compose the host is the service name `db`. For local-native use localhost.
DATABASE_URL=postgresql+psycopg://legiferam:change-me-in-prod@db:5432/legiferam

# ── Auth (MVP/Demo) ───────────────────────────────────────────────────────
# Simple username/password login for the MVP. Replaced by Google OAuth later.
DEMO_USER=demo
DEMO_PASS=demo
# The seeded showcase-law co-author the "Intră ca un co-autor de lege" demo login uses.
DEMO_COAUTHOR_USER=radu.pavel
DEMO_COAUTHOR_PASS=demo
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# ── AI (OpenRouter) — backend only, key never reaches the frontend ─────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers recommended by OpenRouter
OPENROUTER_APP_URL=https://legiferam.ro
OPENROUTER_APP_NAME=Legiferam.ro

# In DEMO mode, run the co-pilot with scripted replies (true) or real LLM calls (false).
AI_DEMO_SCRIPTED=true

# ── Frontend ──────────────────────────────────────────────────────────────
# Base URL the web app uses to reach the API. In compose, nginx proxies /api.
VITE_API_BASE=/api
